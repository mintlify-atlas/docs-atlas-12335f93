  "keyFeatures": [
    "SIOP-2/OIDC4VP compliant authentication endpoints",
    "Verifiable Credentials verification using Trustbloc libraries",
    "JWT token generation from verified credentials",
    "Integration with EBSI TIR and Gaia-X Registry",
    "QR code-based cross-device authentication",
    "Same-device authentication flow support",
    "Multiple request modes (urlEncoded, byValue, byReference)",
    "Configurable credential validation modes"
  ],
  "publicApiSurface": [
    "GET /api/v1/loginQR - Login page with QR code for authentication",
    "GET /api/v2/loginQR - Enhanced login page with QR code",
    "GET /api/v1/authorization - OAuth2 authorization endpoint",
    "GET /api/v1/samedevice - Same device authentication flow",
    "GET /api/v1/startsiop - Initiates SIOP flow and returns connection string",
    "POST /api/v1/authentication_response - Credential submission endpoint",
    "GET /api/v1/authentication_response - Alternative credential submission",
    "POST /token - Token exchange endpoint for authorization code",
    "POST /services/{service_id}/token - Service-specific token endpoint",
    "GET /.well-known/jwks - Public keys for JWT verification",
    "GET /services/{service_id}/.well-known/openid-configuration - OpenID Provider metadata",
    "GET /api/v1/request/{id} - Request object by reference",
    "GET /health - Health check endpoint"
  ]
